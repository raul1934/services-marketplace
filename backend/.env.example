APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Realtime runs on Reverb (Pusher protocol). The app's Echo client authorizes
# private channels via Sanctum at /broadcasting/auth (see routes/channels.php).
# `log`/`null` disable realtime; the running backend uses `reverb`.
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=chamafacil
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Matching: confine dispatch + provider feed to a request's Market (franchise
# territory exclusivity). false = legacy radius-only matching.
# Only turn this on AFTER drawing the Market geofences in /admin — with none
# defined, every request is rejected as out-of-coverage.
MATCHING_TERRITORY_ISOLATION=false

# TEMPORARY — test bots (see config/bots.php). Off by default.
# Turn on only in an environment you're actively testing in, then run
# `php artisan config:clear`. Accounts are created once with `bots:seed`.
# In production BOTS_MARKET_ID must name a real active market — a synthetic
# geofence would capture real customers into the bot territory.
BOTS_ENABLED=false
# BOTS_MARKET_ID=
# BOTS_MAX_BIDS_PER_REQUEST=5
# BOTS_MAX_OPEN_REQUESTS=10

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Modo concierge — avisa a operação de chamado que ficou sem nenhuma proposta,
# enquanto ainda dá tempo de alguém ligar e resolver na mão. Sem
# CONCIERGE_ALERT_EMAIL o detector ainda roda e registra em log, só não avisa
# ninguém. Ver config/concierge.php e a issue MKT-OPS-01.
CONCIERGE_ENABLED=true
CONCIERGE_MINUTES=4
CONCIERGE_MAX_AGE_HOURS=6
CONCIERGE_ALERT_EMAIL=
CONCIERGE_ADMIN_URL=https://admin.chamafacil.app

# Canais do alerta: mail, whatsapp, ou os dois separados por vírgula.
CONCIERGE_CHANNELS=mail

# WhatsApp Cloud API (oficial da Meta). Só usado com 'whatsapp' nos canais.
#
# ATENÇÃO: um número registrado na Cloud API deixa de funcionar no aplicativo
# do WhatsApp. Não registre o número que a landing publica como suporte — use
# um número separado. E o template precisa estar APROVADO no WhatsApp Manager
# antes de ligar o canal: fora da janela de 24h a Meta não entrega outra coisa.
# O template espera três parâmetros no corpo: {{1}} minutos, {{2}} categoria,
# {{3}} endereço.
CONCIERGE_WA_TOKEN=
CONCIERGE_WA_PHONE_ID=
CONCIERGE_WA_TO=
CONCIERGE_WA_TEMPLATE=chamado_sem_proposta
CONCIERGE_WA_TEMPLATE_LANG=pt_BR
CONCIERGE_WA_VERSION=v21.0

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sign in with Google (Socialite). CLIENT_ID = OAuth **Web** client ID.
# O login nativo do app envia um access token; o backend troca por token Sanctum
# via SocialAuthController (userFromToken). REDIRECT não é usado pelo fluxo por
# token, mas o driver do Socialite espera os três valores.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT="${APP_URL}/api/auth/google/callback"

# Social posting (admin → Facebook + Instagram via the Meta Graph API). Only the
# Graph version lives here; the long-lived access tokens are pasted by the super
# admin and stored encrypted in social_connections — never in env.
META_GRAPH_VERSION=v21.0
