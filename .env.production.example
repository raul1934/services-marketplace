# Exemplo das variáveis consumidas por docker-compose.prod.yml.
#
# No servidor Lightsail, copie para `.env` na raiz do projeto e preencha com
# valores reais. O `.env` real NÃO é versionado (está no .gitignore).
#
#   cp .env.production.example .env   &&   nano .env
#
# Estes valores são compartilhados entre o container do Postgres (db) e os
# serviços PHP (backend/queue/reverb/scheduler). Mantenha-os em sincronia:
# se mudar aqui, os dados existentes no volume guincho-db-data continuam com
# a senha antiga — troque a senha do banco explicitamente se precisar rotacionar.

# Aponta para o Lightsail Managed Database (PostgreSQL). O DB_HOST é o endpoint
# do banco gerenciado (…rds.amazonaws.com); os dados vivem lá, não em container.
DB_HOST=seu-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=dbmaster
DB_USERNAME=dbmasteruser
DB_PASSWORD=troque-por-uma-senha-forte
