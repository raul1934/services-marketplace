{
  "expo": {
    "name": "Chama Fácil",
    "slug": "chamafacil-customer",
    "scheme": "chamafacil",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "androidStatusBar": {
      "backgroundColor": "#ff6a3d",
      "barStyle": "light-content",
      "translucent": false
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chamafacil.customer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "android": {
      "package": "com.chamafacil.customer",
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#ffffff" },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-image-picker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "O Chama Fácil usa o microfone para ditar textos por voz.",
          "speechRecognitionPermission": "O Chama Fácil usa reconhecimento de fala para transcrever o que você ditar.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "@reactvision/react-viro",
        {
          "xRMode": ["AR"],
          "cameraUsagePermission": "O Chama Fácil usa a câmera para medir com Realidade Aumentada."
        }
      ]
    ],
    "extra": {
      "router": { "origin": false }
    }
  }
}
