# Provider app config for LOCAL development. The app defaults (src/config.ts)
# now target PRODUCTION (chamafacil.app); copy this file to .env to override
# with the local docker stack. Adjust for your LAN when on a physical device.
# Talks straight to the published backend port (19000) so it never collides
# with other local stacks (e.g. lula on :80 / :8080). When testing on a
# physical device, swap localhost for your machine's LAN IP, keeping the ports.
# e.g. http://192.168.0.10:19000/api/provider/v1
EXPO_PUBLIC_API_URL=http://localhost:19000/api/provider/v1
EXPO_PUBLIC_API_HOST=http://localhost:19000
EXPO_PUBLIC_REVERB_KEY=1kwtg5xpykisjdjv5wlq
EXPO_PUBLIC_REVERB_HOST=localhost
EXPO_PUBLIC_REVERB_PORT=19080
EXPO_PUBLIC_REVERB_TLS=false
