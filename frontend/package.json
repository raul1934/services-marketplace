{
  "name": "chamafacil-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Chama Fácil marketplace — React Native (Expo) monorepo: customer + provider apps sharing a design system, API client and types.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "customer": "npm run start --workspace @chamafacil/customer",
    "provider": "npm run start --workspace @chamafacil/provider",
    "android:customer": "npm run android --workspace @chamafacil/customer",
    "android:provider": "npm run android --workspace @chamafacil/provider",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
