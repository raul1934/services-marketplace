{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // See the apps' tsconfig: .svg imports resolve to sibling .d.svg.ts files.
    "allowArbitraryExtensions": true,
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["src/**/*"]
}
