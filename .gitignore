### Windows
# Windows thumbnail cache files
Thumbs.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows shortcuts
*.lnk

# NTFS "mark of the web" alternate-data-stream artifacts
*Zone.Identifier

### Project-specific
# Local archives (not source)
*.zip

# Claude Code session/plan files
.claude/

# Playwright auth state — regenerated per run, contains live session tokens
e2e/.auth/

# Retired Ionic/Angular frontend — superseded by the Expo apps in frontend/,
# kept locally for reference but no longer tracked
frontend-ionic-legacy/
# Self-hosted OSRM graph + OSM extract (large, generated)
osrm-data/

# Playwright HTML report + trace viewer assets — regenerated per run
e2e/playwright-report/
e2e/test-results/
